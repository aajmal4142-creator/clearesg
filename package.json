{
  "name": "clearesg",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --no-server-fast-refresh",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:calc": "vitest run src/lib/calc src/lib/narrative",
    "test:e2e": "playwright test",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/seed.ts",
    "inspect-esrs": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/inspect-esrs.ts",
    "parse-esrs": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/parse-esrs.ts",
    "propose-mappings": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/propose-mappings.ts",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=9"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.20",
    "@hookform/resolvers": "^5.4.0",
    "@payloadcms/db-mongodb": "^3.86.0",
    "@payloadcms/next": "^3.86.0",
    "@payloadcms/richtext-lexical": "^3.86.0",
    "@payloadcms/ui": "^3.86.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.66.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cross-env": "^10.1.0",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "graphql": "^16.14.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "payload": "^3.86.0",
    "radix-ui": "^1.6.2",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "sharp": "^0.34.2",
    "sonner": "^2.0.7",
    "stripe": "^22.3.2",
    "svix": "^1.97.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "pdf-parse": "^2.4.5",
    "prettier": "^3.9.5",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10",
    "xlsx": "^0.18.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
