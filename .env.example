# =============================================================================
# ClearESG — environment variables
# Copy to `.env` / `.env.local` and fill in. Never commit secrets.
# =============================================================================

# --- App ---
# Public site URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Payload CMS ---
# Random 32+ char secret used to sign Payload JWTs
PAYLOAD_SECRET=change-me-to-a-long-random-string
# MongoDB Atlas connection string (never use free M0 for real data)
DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/clearesg

# --- Clerk (Phase 2) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Resend (Phase 2+) ---
RESEND_API_KEY=
EMAIL_FROM=ClearESG <noreply@clearesg.com>

# --- Stripe (Phase 12) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_CONSULTANT=

# --- Upstash Redis (Phase 7/14 rate limits) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- File storage (Phase 6 Evidence Vault) ---
# UploadThing OR S3-compatible — pick one path in Phase 6
UPLOADTHING_TOKEN=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# --- Observability (Phase 14) ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
